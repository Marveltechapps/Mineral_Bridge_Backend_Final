# ─── Core ───────────────────────────────────────────────────────────────────
# NODE_ENV=production
# PORT=5000
# MONGODB_URI=mongodb://localhost:27017/mineral_bridge
# JWT_SECRET=change-me

# ─── Email OTP (need at least one provider) ─────────────────────────────────
# Option A — Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM=Mineral Bridge <onboarding@resend.dev>

# Option B — SMTP (Gmail app password, SendGrid SMTP, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraccount@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=youraccount@gmail.com

# Emergency local testing when NODE_ENV=production and no mail provider
# EMAIL_OTP_DEV_LOG=1

# ─── Phone OTP — Twilio (recommended for production SMS + WhatsApp) ────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=+1xxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Phone OTP — India legacy SMS gateway (Spear UC / DLT) ───────────────────
# URL must end with & so the backend can append to_mobileno= and sms_text=
# India SMS gateway (Spear UC). Required on EC2 — config/config.json is not committed to git.
# Copy from config/config.json "smsvendor" or run: node scripts/sync-sms-env-to-dotenv.js
# SMS_VENDOR_URL=https://your-sms-gateway.com/api?type=smsquicksend&user=USER&pass=PASS&sender=EVOLGN&t_id=TEMPLATE_ID&
#
# Message must match your DLT-approved template exactly (%s or {otp} = OTP digits):
# OTP_SMS_MESSAGE=Mineral Bridge: Your login code is %s. Valid for 5 minutes.
# See docs/SMS_GET_OTP_ON_DEVICE.md if the gateway returns success but SMS never arrives.

# ─── Phone OTP — dev / QA helpers ────────────────────────────────────────────
# Return OTP in send-otp JSON (non-production always; production only when set):
# OTP_INCLUDE_IN_RESPONSE=1
# OTP_PHONE_DEV_LOG=1
# OTP_TEST_PHONE=9876543210

# ─── Artisanal mineral catalog (optional) ───────────────────────────────────
# ARTISANAL_CATALOG_PATH=data/artisanalMineralCatalog.json
